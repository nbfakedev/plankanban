# Server
NODE_ENV=development
PORT=3000
BASE_URL=https://your-domain.tld

# Postgres
PGHOST=localhost
PGPORT=5432
PGDATABASE=kanban
PGUSER=kanban
PGPASSWORD=kanban_password
DATABASE_URL=postgres://kanban:kanban_password@localhost:5432/kanban

# Auth
JWT_SECRET=change_me
JWT_TTL_HOURS=24

# LLM gateway (ключи добавляются вручную в Профиль → LLM провайдеры при первом запуске)
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4
LLM_RATE_LIMIT_PER_MINUTE=30
LLM_ALLOWED_MODELS_ANTHROPIC=claude-sonnet-4,claude-haiku-4-5-20251001
LLM_STUB_MODE=0

# Серверный API-ключ (оставьте пустым — ключи добавляются через Профиль)
ANTHROPIC_API_KEY=
CLOUDFLARE_WORKER_URL=https://your-worker.workers.dev
WORKER_SHARED_SECRET=change_me

# LLM user-level provider settings (optional)
# Keys in llm_provider_settings are encrypted with this secret. If unset, JWT_SECRET is used (not recommended in production).
LLM_USER_KEYS_ENCRYPTION_SECRET=change_me_32_chars_min
